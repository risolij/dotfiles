## Rofi Settings

rofi.color-enabled:	true
rofi.color-normal:  #292421,  #d3d3d3,  #292421,  #292421,  #7e62b3
!rofi.color-urgent: #292421,  #dc322f,  #eee8d5,  #dc322f,  #fdf6e3
!rofi.color-active: #292421,  #268bd2,  #eee8d5,  #268bd2,  #fdf6e3

rofi.color-window: #292421,  #d3d3d3
rofi.separator-style:	solid
rofi.hide-scrollbar:	true
rofi.lines:		10
rofi.columns:		2

