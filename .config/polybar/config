[colors]
background = #222
background-alt = #444
foreground = #dfdfdf
foreground-alt = #555
primary = #ffb52a
secondary = #e60053
alert = #bd2c40

linecolor = #fba922
bordercolor = #333
accent = #e60053

uline = #43a6a6

[bar/panel]
enable-ipc = true
width = 90%
height = 30
fixed-center = true

offset-x = 5%
offset-y = 5
#radius = 6.0

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3
line-color = ${colors.linecolor}

overline-size = 3
overline-color = ${colors.accent}
underline-size = 3
underline-color = ${colors.accent}

border-size = 4
border-color = #00000000

padding-left = 0
padding-right = 2

module-margin-left = 2
module-margin-right = 1

font-0 = Inconsolata:style=Regular:pixelsize=10;1
font-1 = Inconsolata:style=Bold:pixelsize=10;1
font-2 = fixed:pixelsize=10;1
font-3 = Font Awesome 5 Free:style=Regular:pixelsize=10
font-4 = Font Awesome 5 Free:style=Solid:pixelsize=10
font-5 = Font Awesome 5 Free Brands:style=Regular:pixelsize=10


modules-left = ewmh xwindow
modules-center = alsa
modules-right = wlan battery temperature date

tray-position = right
tray-padding = 9
tray-maxsize = 18


[module/xwindow]
type = internal/xwindow
label = %title: %

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix = "Ņē» "
format-prefix-foreground = ${colors.foreground-alt}
format-prefix-underline = ${colors.secondary}

label-layout = %layout%
label-layout-underline = ${colors.secondary}

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = ${colors.secondary}
label-indicator-underline = ${colors.secondary}

[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /

label-mounted = %{F#0a81f5}%mountpoint%%{F-}: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}


[module/mpd]
type = internal/mpd
format-online = <label-song>  <icon-prev> <icon-stop> <toggle> <icon-next>

icon-prev = Ņé¢
icon-stop = ŅéÖ
icon-play = ŅéÜ
icon-pause = Ņéø
icon-next = Ņé£

label-song-maxlen = 25
label-song-ellipsis = true

[module/xbacklight]
type = internal/xbacklight

format = <label> <bar>
label = BL

bar-width = 10
bar-indicator = |
bar-indicator-foreground = #fff
bar-indicator-font = 2
bar-fill = ŌöĆ
bar-fill-font = 2
bar-fill-foreground = #9f78e1
bar-empty = ŌöĆ
bar-empty-font = 2
bar-empty-foreground = ${colors.foreground-alt}

[module/backlight-acpi]
inherit = module/xbacklight
type = internal/backlight
card = intel_backlight

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "ŅĆ” "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = #f90000
label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = "ŅĆ© "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = #4bffdc
label = %percentage_used%%

[module/wlan]
type = internal/network
interface = wlp2s0
interval = 3.0

format-connected = <ramp-signal> <label-connected>
format-connected-underline = ${colors.uline}
label-connected = %essid%

format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

ramp-signal-0 = Ņłś
ramp-signal-1 = ŅłÖ
ramp-signal-2 = ŅłÜ
ramp-signal-3 = ŅłÜ
ramp-signal-4 = ŅłÜ
ramp-signal-foreground = ${colors.foreground-alt}

[module/eth]
type = internal/network
interface = enp1s0
interval = 3.0

format-connected-underline = #55aa55
format-connected-prefix = "Ņå£ "
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %local_ip%

format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

[module/date]
type = internal/date
interval = 5

date =
date-alt = " %Y-%m-%d"

time = %H:%M
time-alt = %H:%M:%S

format-prefix = ŅĆ¢
format-prefix-foreground = ${colors.foreground-alt}
format-underline = ${colors.uline}

label = %date% %time%

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume> <bar-volume>
label-volume = Vol %percentage%%
label-volume-foreground = ${root.foreground}

label-muted = ­¤öć muted
label-muted-foreground = #666

bar-volume-width = 10
bar-volume-foreground-0 = ${colors.uline}
bar-volume-foreground-1 = ${colors.uline}
bar-volume-foreground-2 = ${colors.uline}
bar-volume-foreground-3 = ${colors.uline}
bar-volume-foreground-4 = ${colors.uline}
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ŌöĆ
bar-volume-fill-font = 2
bar-volume-empty = ŌöĆ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/alsa]
type = internal/alsa

format-volume = <label-volume> <bar-volume>
label-volume = ’Ć©
label-volume-foreground = ${root.foreground}

format-muted-prefix = "Ņłé "
format-muted-foreground = ${colors.foreground-alt}
label-muted = sound muted

bar-volume-width = 10
bar-volume-foreground-0 = ${colors.uline}
bar-volume-foreground-1 = ${colors.uline}
bar-volume-foreground-2 = ${colors.uline}
bar-volume-foreground-3 = ${colors.uline}
bar-volume-foreground-4 = ${colors.uline}
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ŌöĆ
bar-volume-fill-font = 2
bar-volume-empty = ŌöĆ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/battery]
type = internal/battery
battery = BAT1
adapter = ACAD
full-at = 98

format-charging = <animation-charging> <label-charging>
format-charging-underline = ${colors.uline}

format-discharging = <animation-discharging> <label-discharging>
format-discharging-underline = ${self.format-charging-underline}

format-full-prefix = "Ņł║ "
format-full-prefix-foreground = ${colors.foreground-alt}
format-full-underline = ${self.format-charging-underline}

ramp-capacity-0 = ŅłČ
ramp-capacity-1 = ŅłĘ
ramp-capacity-2 = ŅłĖ
ramp-capacity-foreground = ${colors.foreground-alt}

animation-charging-0 = ŅłČ
animation-charging-1 = ŅłĘ
animation-charging-2 = ŅłĖ
animation-charging-foreground = ${colors.foreground-alt}
animation-charging-framerate = 750

animation-discharging-0 = ŅłĖ
animation-discharging-1 = ŅłĘ
animation-discharging-2 = ŅłČ
animation-discharging-foreground = ${colors.foreground-alt}
animation-discharging-framerate = 750

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60

format = <ramp> <label>
format-underline = ${colors.uline}
format-warn = <ramp> <label-warn>
format-warn-underline = ${self.format-underline}

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.secondary}

ramp-0 = Ņāē
ramp-1 = ŅāŖ
ramp-2 = Ņāŗ
ramp-foreground = ${colors.foreground-alt}

[module/powermenu]
type = custom/menu

expand-right = true

format-spacing = 1

label-open = Ņäī
label-open-foreground = ${colors.secondary}
label-close = Ņüź cancel
label-close-foreground = ${colors.secondary}
label-separator = |
label-separator-foreground = ${colors.foreground-alt}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = sudo reboot

menu-2-0 = power off
menu-2-0-exec = sudo poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

[module/ewmh]
type = internal/xworkspaces

icon-0 = 1;’äĀ
icon-1 = 2;’äĮ 
icon-2 = 3;’øĢ  
icon-3 = 4;’øÖ  

pin-workspaces = false
enable-click = true
enable-scroll = true

label-active-padding = 4
label-occupied-padding = 4
label-empty-padding = 4

format = <label-state>
label-monitor = %name%

label-active = %icon% 
label-active-foreground = #ffffff
label-active-background = #3f3f3f
label-active-underline = ${colors.uline}

label-occupied = %icon% 
label-occupied-underline = #555555

label-urgent = %icon% 
label-urgent-foreground = #000000
label-urgent-background = #bd2c40
label-urgent-underline = #9b0a20

label-empty = %icon% 
label-empty-foreground = #55

[settings]
screenchange-reload = true


[global/wm]
margin-top = 5
margin-bottom = 5

